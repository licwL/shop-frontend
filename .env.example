# ==========================================
# 电商平台 Docker 部署 — 环境变量
# 复制为 .env 并填入真实值:
#   cp .env.example .env
# ==========================================

# MySQL 数据库
MYSQL_ROOT_PASSWORD=请设置MySQL的root密码
DB_PASSWORD=请设置shop用户的密码

# 阿里云 OSS（图片存储）
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=请填写AccessKey ID
OSS_ACCESS_KEY_SECRET=请填写AccessKey Secret
OSS_BUCKET_NAME=shop-calvin-lcw
